# ============================================================
# Concert Ticket Jastip - Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# Base URL for the backend REST API (no trailing slash)
VITE_API_BASE_URL=http://localhost:3000/api

# Midtrans Snap.js CDN URL
VITE_MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js

# Midtrans client key (public key, safe to expose in the browser)
VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx
